<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>crab gallery</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

    <div class="gallery-container">
        <!-- Big In-Focus Image -->
        <div class="featured-wrapper">
            <img loading="lazy" width="{{image.width}}" height="{{image.height}}" id="featured" class="featured-image" src="/images/{{ image.title }}">
        </div>

        <!-- Previous / Next Thumbnail List -->
        <div id="thumbnails" class="thumbnail-list">
          {% for i in thumbnails %}
          <div class="thumbnail-item">
            <a href="/view/{{i.title}}">
              <img loading="lazy" src="/images/{{i.title}}?w=120&h=80&fit=contain" />
            </a>
          </div>
          {% endfor %}
        </div>
    </div>
</body>
</html>
